 ggml/src/ggml-cuda/ggml-cuda.cu |  54 +++++++++
 ggml/src/ggml-cuda/norm.cu      | 196 ++++++++++++++++++++++++++++++++
 ggml/src/ggml-cuda/norm.cuh     |   5 +
