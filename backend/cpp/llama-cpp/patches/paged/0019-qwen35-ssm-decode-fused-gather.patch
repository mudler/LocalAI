+        const int32_t * ids     = (const int32_t *) src_ids->data;
+        bool identity = true;
+        for (int64_t s = 0; s < n_seqs; ++s) {
+            if (ids[s] != rs_head + (int32_t) s) { identity = false; break; }
+        }
+        state_seq_stride = D;
+        state_in_base = identity
