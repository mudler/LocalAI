+        ggml_cuda_kernel_launch(rms_norm_pre_add_mul_out<1024, Tdst>, lp,
+            a, b, h_out, dst, ncols, stride_row, stride_channel, stride_sample, eps,
+            mul, mul_stride_row, mul_stride_channel, mul_stride_sample, mc, mr, mch, ms);
+    }
+}
