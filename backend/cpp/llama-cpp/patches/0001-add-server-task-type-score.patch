+                        out[j + 1] = (float) ((double) logits[sfx[j + 1]] - log_denom);
+                    }
+                }
+            }
+
+            for (size_t k = 0; k < chunk.size(); ++k) {
+                llama_memory_seq_rm(mem, seq_base + (llama_seq_id) k, -1, -1);
+            }
+
+            llama_batch_free(fb);
+
+            if (ret != 0) {
+                SLT_ERR(slot, "score suffix decode failed, ret = %d\n", ret);
+                return false;
+            }
+        }
+
+        return true;
+    }
