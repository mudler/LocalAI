+static inline bool ggml_cuda_moe_whole_pattern_exec_trace_take(std::atomic<int> & counter) {
+    const int trace_limit = ggml_cuda_moe_whole_pattern_exec_trace_limit();
+    if (trace_limit <= 0) {
