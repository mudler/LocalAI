+//
+// server_task_result_score
+//
+json server_task_result_score::to_json() {
+    json tokens = json::array();
+    for (const auto & p : token_logprobs) {
+        tokens.push_back(json {
+            {"id",      p.first},
+            {"logprob", p.second},
+        });
+    }
+    return json {
+        {"index",         index},
+        {"log_prob",      log_prob},
+        {"tokens_scored", n_tokens},
+        {"tokens",        std::move(tokens)},
+    };
+}
