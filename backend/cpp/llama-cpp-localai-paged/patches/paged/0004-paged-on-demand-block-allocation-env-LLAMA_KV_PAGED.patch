 src/llama-kv-cache.cpp |  69 +++++++++++++++++----------
 src/paged-alloc.cpp    | 106 +++++++++++++++++++++++++++++++++++++++++
 src/paged-alloc.h      |  39 +++++++++++++++
 4 files changed, 190 insertions(+), 25 deletions(-)
 create mode 100644 src/paged-alloc.cpp
 create mode 100644 src/paged-alloc.h

